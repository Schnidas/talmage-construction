---
import { contact, services, business } from '../data/site';
---

<section class="cta" id="contact">
  <div class="container-x grid">
    <div class="pitch">
      <p class="eyebrow" data-reveal>Free Estimate</p>
      <h2 class="display-md" data-reveal data-reveal-delay="0.05">
        Contact <span class="accent">Us</span>
      </h2>
      <p class="lede" data-reveal data-reveal-delay="0.1">
        Tell us about your space. Isaac Talmage will reach out with honest advice and a fair,
        no-pressure quote.
      </p>

      <ul class="facts" data-reveal data-reveal-delay="0.15">
        <li>
          <span class="k">Call</span>
          <a href={contact.phoneHref}>{contact.phone}</a>
        </li>
        <li>
          <span class="k">Visit</span>
          <span>{contact.address}</span>
        </li>
        <li>
          <span class="k">Hours</span>
          <span>{contact.hours}</span>
        </li>
        <li>
          <span class="k">Area</span>
          <span>{business.serviceArea}</span>
        </li>
      </ul>
    </div>

    <form class="form" data-estimate-form data-reveal data-reveal-delay="0.1" novalidate>
      {/* Honeypot: hidden from people, bots fill it and get silently dropped */}
      <div class="hp-field" aria-hidden="true">
        <label>Company<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
      </div>
      <div class="field">
        <label for="name">Name</label>
        <input id="name" name="name" type="text" autocomplete="name" required placeholder="Your name" />
      </div>
      <div class="row">
        <div class="field">
          <label for="phone">Phone</label>
          <input id="phone" name="phone" type="tel" autocomplete="tel" required placeholder="(425) 000-0000" />
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" autocomplete="email" placeholder="you@email.com" />
        </div>
      </div>
      <div class="field">
        <label for="project">Project</label>
        <select id="project" name="project">
          {services.map((s) => <option value={s.title}>{s.title}</option>)}
          <option value="Other">Something else</option>
        </select>
      </div>
      <div class="field">
        <label for="message">Tell us about it</label>
        <textarea id="message" name="message" rows="4" placeholder="A few details about your space and what you'd like to change…"></textarea>
      </div>
      <button class="submit" type="submit">
        Request my estimate
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"
          ><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <p class="form-note" data-form-note role="status" aria-live="polite">
        No spam, ever. We'll only use this to talk about your project.
      </p>
    </form>
  </div>
</section>

<style>
  .hp-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .cta {
    padding-block: clamp(5rem, 12vh, 9rem);
    background: var(--color-bone-200);
    border-top: 1px solid var(--color-line);
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 6vw, 5rem);
  }
  .cta .eyebrow {
    color: var(--color-clay);
    margin-bottom: 1rem;
  }
  .accent {
    color: var(--color-clay);
  }
  .lede {
    margin-top: 1.5rem;
    color: var(--color-ink-soft);
    max-width: 30rem;
  }
  .facts {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    display: grid;
    gap: 1.1rem;
    max-width: 30rem;
  }
  .facts li {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 1rem;
    align-items: baseline;
    padding-bottom: 1.1rem;
    border-bottom: 1px solid var(--color-line);
  }
  .facts .k {
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    font-weight: 700;
  }
  .facts a {
    color: var(--color-ink);
    text-decoration: none;
    font-weight: 700;
  }
  .facts a:hover {
    color: var(--color-clay);
  }

  .form {
    background: var(--color-bone);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    box-shadow: 0 30px 60px -45px rgb(var(--shadow-rgb) /0.5);
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    margin-bottom: 1.1rem;
  }
  .row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.1rem;
  }
  label {
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-ink-soft);
  }
  input,
  select,
  textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-ink);
    background: color-mix(in srgb, var(--color-bone) 40%, #fff 60%);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    padding: 0.8rem 0.9rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--color-clay);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-clay) 20%, transparent);
  }
  textarea {
    resize: vertical;
  }
  .submit {
    width: 100%;
    margin-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    background: var(--color-ink);
    color: var(--color-bone);
    border: none;
    border-radius: var(--radius-pill);
    padding: 1rem 1.5rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: background 0.25s, transform 0.25s, gap 0.25s;
  }
  .submit:hover {
    background: var(--color-clay);
    transform: translateY(-2px);
    gap: 0.9rem;
  }
  .form-note {
    margin: 1rem 0 0;
    font-size: 0.85rem;
    color: var(--color-ink-soft);
    text-align: center;
  }
  .form-note.is-error {
    color: var(--color-clay-deep);
    font-weight: 600;
  }
  .form-note.is-success {
    color: var(--color-ink);
    font-weight: 600;
  }
  @media (min-width: 560px) {
    .row {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 940px) {
    .grid {
      grid-template-columns: 1fr 30rem;
      align-items: start;
    }
  }
</style>

<script is:inline define:vars={{ ownerEmail: contact.email, phone: contact.phone }}>
  // Progressive form handling. With no backend configured we compose an email
  // to the owner via mailto (works everywhere). To deliver server-side later,
  // set window.__ESTIMATE_ENDPOINT__ to a Formspree/Web3Forms URL and this will
  // POST JSON there instead.
  (function () {
    const form = document.querySelector('[data-estimate-form]');
    if (!form) return;
    const note = form.querySelector('[data-form-note]');
    const setNote = (msg, kind) => {
      if (!note) return;
      note.textContent = msg;
      note.classList.remove('is-error', 'is-success');
      if (kind) note.classList.add('is-' + kind);
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form).entries());
      if (!data.name || !data.phone) {
        setNote('Please add your name and a phone number so we can reach you.', 'error');
        return;
      }

      // Post to the shared Talmage Construction lead backend.
      try {
        const res = await fetch('/api/leads', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ ...data, source: 'remodeling-astro' }),
        });
        const out = await res.json().catch(() => ({}));
        if (!res.ok || !out.ok) throw new Error(out.error || 'bad status');
        form.reset();
        setNote("Thanks! Your request is in. We'll call you shortly.", 'success');
        return;
      } catch (err) {
        // If the backend is unreachable, fall back to opening their email app
        // so the lead is never lost.
      }

      // mailto fallback
      const subject = encodeURIComponent('Estimate request: ' + (data.project || 'Remodel'));
      const body = encodeURIComponent(
        `Name: ${data.name}\nPhone: ${data.phone}\nEmail: ${data.email || 'not provided'}\nProject: ${data.project || 'not provided'}\n\n${data.message || ''}`,
      );
      window.location.href = `mailto:${ownerEmail}?subject=${subject}&body=${body}`;
      setNote('Opening your email app to send the request to Talmage Construction…', 'success');
    });
  })();
</script>
