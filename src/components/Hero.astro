---
import { business, contact } from '../data/site';
---

<section class="hero" id="top">
  <div class="hero-bg" data-hero-bg>
    <video
      src="/images/hero-bg.mp4"
      poster="/images/hero.jpg"
      autoplay
      muted
      loop
      playsinline
      aria-hidden="true"
    ></video>
    <div class="scrim" aria-hidden="true"></div>
  </div>

  <div class="hero-inner container-x" data-hero-content>
    <div class="hero-text">
      <p class="eyebrow" data-reveal>
        <span class="dot"></span>
        <span class="area area--full">{business.serviceArea}</span>
        <span class="area area--short">Salem, OR</span>
      </p>

      <h1 class="headline" data-reveal data-reveal-delay="0.06">
        Veteran-built.<br /><span class="accent">Family-owned.</span>
      </h1>

      <p class="hero-sub" data-reveal data-reveal-delay="0.1">
        Custom home builds, additions &amp; remodels — done right across the Willamette Valley.
      </p>

      <div class="hero-actions" data-reveal data-reveal-delay="0.14">
        <a class="btn-primary" href="#contact">
          Get a Free Estimate
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"
            ><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a class="btn-ghost" href={contact.phoneHref}>Call {contact.phone}</a>
      </div>
    </div>
  </div>

  <!-- Rating card -->
  <div class="hero-card" data-reveal data-reveal-delay="0.2">
    <span class="hc-stars" aria-hidden="true">★★★★★</span>
    <span class="hc-score">{business.rating.score}</span>
    <span class="hc-label">{business.rating.count} {business.rating.source} reviews</span>
  </div>

</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    padding-top: var(--header-h);
    isolation: isolate;
    background: var(--color-char);
  }

  /* Background video layer */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    will-change: transform;
  }
  .hero-bg video,
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    transform: scale(1.06);
  }
  .scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, rgb(12 10 9 / 0.90) 0%, rgb(12 10 9 / 0.35) 40%, rgb(12 10 9 / 0.1) 68%, rgb(12 10 9 / 0.48) 100%),
      linear-gradient(to right, rgb(12 10 9 / 0.65) 0%, rgb(12 10 9 / 0.15) 52%, rgb(12 10 9 / 0) 100%);
  }

  /* Anchor hero content to the viewport's left gutter (not the centered 88rem
     container) so the title hugs the left on wide monitors, like it does on
     mobile. container-x still supplies the gutter via padding-inline. */
  .hero-inner {
    position: relative;
    z-index: 2;
    padding-block: 0 clamp(4rem, 13vh, 9rem);
    max-width: none;
    margin-inline: 0;
  }
  /* Readable column width, left-aligned at the gutter. */
  .hero-text {
    max-width: 54rem;
  }
  .eyebrow {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.55rem;
    line-height: 1.5;
    color: color-mix(in srgb, var(--color-bone) 72%, transparent);
    margin-bottom: 1.4rem;
  }
  .dot {
    width: 8px;
    height: 8px;
    flex-shrink: 0;
    /* sit on the first text line, not the vertical center of a wrapped block */
    margin-top: 0.45em;
    border-radius: var(--radius-pill);
    background: var(--color-clay-on-dark);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-clay-on-dark) 22%, transparent);
  }
  /* Desktop shows the full service-area list; the short label is mobile-only. */
  .area--short {
    display: none;
  }
  .headline {
    font-size: clamp(3.2rem, 1rem + 6.4vw, 7rem);
    line-height: 0.97;
    letter-spacing: -0.03em;
    color: var(--color-bone);
    text-shadow: 0 2px 30px rgb(0 0 0 / 0.35);
  }
  .headline .accent {
    color: var(--color-clay-on-dark);
  }
  .hero-sub {
    margin-top: 1.4rem;
    max-width: 38rem;
    font-size: clamp(1.05rem, 0.95rem + 0.5vw, 1.35rem);
    line-height: 1.45;
    color: color-mix(in srgb, var(--color-bone) 82%, transparent);
    text-shadow: 0 1px 16px rgb(0 0 0 / 0.4);
  }
  .hero-actions {
    margin-top: 2.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--color-bone);
    color: var(--color-ink);
    text-decoration: none;
    padding: 1rem 1.6rem;
    border-radius: var(--radius-pill);
    font-weight: 600;
    transition: background 0.25s, transform 0.25s, gap 0.25s, color 0.25s;
  }
  .btn-primary:hover {
    background: var(--color-clay);
    color: var(--color-bone);
    transform: translateY(-2px);
    gap: 0.9rem;
  }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 1rem 1.5rem;
    border-radius: var(--radius-pill);
    border: 1px solid color-mix(in srgb, var(--color-bone) 55%, transparent);
    color: var(--color-bone);
    text-decoration: none;
    font-weight: 600;
    transition: background 0.25s, border-color 0.25s;
  }
  .btn-ghost:hover {
    background: color-mix(in srgb, var(--color-bone) 14%, transparent);
    border-color: var(--color-bone);
  }

  /* Rating card — bottom-right on desktop, top-right on mobile */
  .hero-card {
    position: absolute;
    z-index: 2;
    right: var(--gutter);
    /* Match the hero content's bottom padding so the card sits on the same
       baseline as the CTA buttons and clears the .page-rise panel overlap
       (otherwise the cream panel rises over and clips the card). */
    bottom: clamp(4rem, 13vh, 9rem);
    display: grid;
    gap: 0.25rem;
    padding: 1.1rem 1.4rem;
    border-radius: var(--radius-card);
    background: color-mix(in srgb, var(--color-char) 92%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-bone) 14%, transparent);
    box-shadow: 0 20px 50px -28px rgb(0 0 0 / 0.8);
  }
  .hc-stars {
    color: var(--color-clay-on-dark);
    letter-spacing: 2px;
    font-size: 0.95rem;
  }
  .hc-score {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 2.4rem;
    line-height: 1;
    color: var(--color-bone);
  }
  .hc-label {
    color: color-mix(in srgb, var(--color-bone) 66%, transparent);
    font-size: 0.85rem;
  }

  @media (max-width: 720px) {
    .hero-inner {
      /* Sit the CTA row low in the section, but still above the .page-rise panel
         that overlaps the hero bottom by ~2.5rem (SitePage margin-top clamp). */
      padding-bottom: clamp(3.25rem, 7vh + 1rem, 4.5rem);
    }
    /* Bigger headline on mobile */
    .headline {
      font-size: clamp(3.4rem, 2.4rem + 4.5vw, 5rem);
    }
    .hero-sub {
      margin-top: 1rem;
      font-size: 1rem;
    }
    /* Mobile shows the short "Washington State" label, not the full list. */
    .area--full {
      display: none;
    }
    .area--short {
      display: inline;
    }
    /* Compact eyebrow badge on mobile — single line now, so center the dot. */
    .eyebrow {
      align-items: center;
      font-size: 0.7rem;
      gap: 0.45rem;
      margin-bottom: 1.1rem;
    }
    .dot {
      width: 7px;
      height: 7px;
      margin-top: 0;
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-clay-on-dark) 22%, transparent);
    }
    /* CTA buttons share one row: two equal pills, tighter and smaller. */
    .hero-actions {
      margin-top: 1.5rem;
      flex-wrap: nowrap;
      gap: 0.6rem;
    }
    .btn-primary,
    .btn-ghost {
      flex: 1 1 0;
      min-width: 0;
      justify-content: center;
      padding: 0.8rem 0.7rem;
      font-size: 0.9rem;
      white-space: nowrap;
    }
    /* Drop the arrow on mobile so the full "Get a Free Estimate" label fits. */
    .btn-primary svg {
      display: none;
    }

    /* Rating card moves to top-right, smaller */
    .hero-card {
      bottom: auto;
      top: calc(var(--header-h) + 1rem);
      right: var(--gutter);
      padding: 0.6rem 0.85rem;
      gap: 0.2rem;
    }
    .hc-score {
      font-size: 1.4rem;
    }
    .hc-label {
      font-size: 0.75rem;
    }
    .hc-stars {
      font-size: 0.8rem;
    }
  }
</style>
