---
import { reasons, business } from '../data/site';
import ScrollText from './ScrollText.astro';

const ICONS = [
  // Family-owned: home
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  // In time: clock
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  // Built to last: shield
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
];
---

<section class="choose" data-parallax-scope>
  <div class="container-x">
    <div class="top">
      <p class="eyebrow" data-reveal>Why Choose Us</p>
      <ScrollText
        as="h2"
        class="display-md headline"
        text="A family name on every job, and a reputation worth protecting."
        accent={['family', 'protecting.']}
      />
    </div>

    <div class="layout">
      <ul class="reasons" role="list">
        {
          reasons.map((r, i) => (
            <li class="reason" data-reveal data-reveal-delay={i * 0.05}>
              <span class="icon" set:html={ICONS[i] ?? ICONS[0]}></span>
              <h3>{r.title}</h3>
              <p>{r.body}</p>
            </li>
          ))
        }
      </ul>

      <aside class="stat" data-reveal>
        <div class="score">{business.rating.score}</div>
        <div class="stars" aria-hidden="true">★★★★★</div>
        <p>
          Across <strong>{business.rating.count}</strong> {business.rating.source} reviews: a perfect
          rating, earned one careful project at a time.
        </p>
      </aside>
    </div>
  </div>
</section>

<style>
  .choose {
    background: var(--color-char);
    color: var(--color-bone);
    padding-block: clamp(5rem, 13vh, 10rem);
  }
  .choose .eyebrow {
    color: var(--color-clay-on-dark);
    margin-bottom: 1.25rem;
  }
  .choose :global(.scrollfill) {
    color: color-mix(in srgb, var(--color-bone) 32%, var(--color-char));
  }
  .choose :global(.scrollfill .word.is-lit) {
    color: var(--color-bone);
  }
  .choose :global(.scrollfill .word.accent.is-lit) {
    color: var(--color-clay);
  }
  .top {
    max-width: 50rem;
    margin-bottom: clamp(3rem, 8vh, 5rem);
  }
  .layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 6vw, 4.5rem);
  }
  .reasons {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .reason {
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-char-700);
  }
  .icon {
    display: flex;
    color: var(--color-clay-on-dark);
    margin-bottom: 1rem;
  }
  .reason h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .reason p {
    color: color-mix(in srgb, var(--color-bone) 62%, var(--color-char));
    margin: 0;
  }
  .stat {
    background: var(--color-char-700);
    border-radius: var(--radius-card);
    padding: clamp(2rem, 4vw, 3rem);
    align-self: start;
  }
  .score {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(4rem, 3rem + 6vw, 7rem);
    line-height: 0.9;
    color: var(--color-bone);
  }
  .stars {
    color: var(--color-clay);
    letter-spacing: 4px;
    font-size: 1.5rem;
    margin: 0.5rem 0 1.25rem;
  }
  .stat p {
    color: color-mix(in srgb, var(--color-bone) 66%, var(--color-char));
  }
  .stat strong {
    color: var(--color-bone);
  }
  @media (min-width: 720px) {
    .reasons {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem 3rem;
    }
  }
  @media (min-width: 1040px) {
    .layout {
      grid-template-columns: 1fr 22rem;
      align-items: start;
    }
  }
</style>
