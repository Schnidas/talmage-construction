---
import { process } from '../data/site';
const ordinals = ['one', 'two', 'three', 'four', 'five'];
---

<section class="process container-x" id="process">
  <div class="intro">
    <p class="eyebrow" data-reveal>How It Works</p>
    <h2 class="display-md" data-reveal data-reveal-delay="0.05">
      Three steps.<br />Zero surprises.
    </h2>
    <p class="sub" data-reveal data-reveal-delay="0.1">
      A simple, honest process: the way a family business should run it.
    </p>
  </div>

  <div class="steps-col">
    <ol class="steps" role="list" data-process-steps>
      <!-- Animated fill line (grows top-to-bottom on scroll) -->
      <div class="line-fill" data-process-line aria-hidden="true"></div>

      {
        process.map((step, i) => (
          <li class="step" data-process-step>
            <div class="rail" aria-hidden="true">
              <span class="node"></span>
            </div>
            <div class="step-body">
              <span class="kicker">Step {ordinals[i]}</span>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </div>
          </li>
        ))
      }
    </ol>

    <a class="btn-primary" href="#contact" data-reveal>
      Start your project
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"
        ><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>
</section>

<style>
  .process {
    padding-block: clamp(5rem, 12vh, 9rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 6vw, 5rem);
  }
  .intro .eyebrow {
    color: var(--color-clay);
    margin-bottom: 1rem;
  }
  .sub {
    margin-top: 1.25rem;
    color: var(--color-ink-soft);
    max-width: 26rem;
  }

  /* Right column: steps list + button stacked */
  .steps-col {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    align-items: flex-start;
  }

  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
    width: 100%;
  }

  /* Animated clay line that grows from top as user scrolls */
  .line-fill {
    position: absolute;
    left: 0.74rem;
    top: 2.1rem;
    bottom: 2.1rem;
    width: 2px;
    background: var(--color-clay);
    transform-origin: top center;
    transform: scaleY(0);
    pointer-events: none;
    z-index: 2;
  }

  .step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.75rem;
  }

  /* Vertical timeline rail */
  .rail {
    position: relative;
    display: flex;
    justify-content: center;
    width: 1.5rem;
  }
  .rail::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-line);
  }
  .step:first-child .rail::before {
    top: 1.4rem;
  }
  .step:last-child .rail::before {
    bottom: calc(100% - 1.4rem);
  }
  .node {
    position: relative;
    z-index: 3;
    margin-top: 1.05rem;
    width: 0.85rem;
    height: 0.85rem;
    border-radius: var(--radius-pill);
    background: var(--color-bone);
    border: 3px solid var(--color-clay);
    transition: background 0.3s, transform 0.3s;
  }
  .step:hover .node {
    background: var(--color-clay);
    transform: scale(1.25);
  }
  .step-body {
    padding-block: clamp(0.75rem, 3vh, 1.75rem) clamp(1.75rem, 4vh, 2.75rem);
  }
  .kicker {
    display: inline-block;
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-clay);
    margin-bottom: 0.6rem;
  }
  .step-body h3 {
    font-size: clamp(1.5rem, 1.2rem + 1.5vw, 2.25rem);
    margin-bottom: 0.5rem;
  }
  .step-body p {
    color: var(--color-ink-soft);
    margin: 0;
    max-width: 38rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--color-ink);
    color: var(--color-bone);
    text-decoration: none;
    padding: 1rem 1.6rem;
    border-radius: var(--radius-pill);
    font-weight: 600;
    transition: background 0.25s, transform 0.25s, gap 0.25s;
  }
  .btn-primary:hover {
    background: var(--color-clay);
    transform: translateY(-2px);
    gap: 0.9rem;
  }

  /* Steps are hidden when motion is enabled; JS reveals them at a later scroll point */
  :global(html.has-motion) .step {
    opacity: 0;
    transform: translateY(2.5rem);
    will-change: transform, opacity;
  }

  @media (min-width: 900px) {
    .process {
      grid-template-columns: 22rem 1fr;
      align-items: start;
    }
    .intro {
      position: sticky;
      top: calc(var(--header-h) + 2.5rem);
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    gsap.registerPlugin(ScrollTrigger);

    // Reveal each step later than default (user must scroll more to trigger)
    document.querySelectorAll('[data-process-step]').forEach((step) => {
      gsap.fromTo(
        step,
        { opacity: 0, y: 40 },
        {
          opacity: 1,
          y: 0,
          duration: 0.95,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: step,
            start: 'top 72%',
            once: true,
          },
        },
      );
    });

    // Animate the clay fill line: grows from top to bottom as user scrolls through steps
    const lineEl = document.querySelector('[data-process-line]');
    const stepsEl = document.querySelector('[data-process-steps]');
    if (lineEl && stepsEl) {
      gsap.to(lineEl, {
        scaleY: 1,
        ease: 'none',
        scrollTrigger: {
          trigger: stepsEl,
          start: 'top 58%',
          end: 'bottom 50%',
          scrub: 0.8,
        },
      });
    }
  }
</script>
