---
import { business, contact, nav } from '../data/site';
const year = 2026;
---

<footer class="footer">
  <div class="container-x">
    <div class="top">
      <div class="col brandcol">
        <p class="tagline">{business.tagline}</p>
        <p class="blurb">{business.about}</p>
        <a class="cta" href={contact.phoneHref}>Call {contact.phone}</a>
      </div>

      <nav class="col navcol" aria-label="Footer">
        <span class="k">Explore</span>
        {nav.map((i) => <a href={i.href}>{i.label}</a>)}
      </nav>

      <div class="col">
        <span class="k">Visit</span>
        <p>{contact.address}</p>
        <p>{contact.hours}</p>
        <a href={contact.googleReviewsUrl} target="_blank" rel="noopener">{business.rating.score}★ on {business.rating.source} →</a>
      </div>

      <div class="col">
        <span class="k">Serving</span>
        <p>{business.serviceArea}</p>
        <a href="#contact">Get a free estimate →</a>
      </div>
    </div>

    <div class="wordmark" aria-hidden="true">Talmage Construction</div>

    <div class="legal">
      <span>© {year} {business.legalName}. Licensed &amp; insured.</span>
      <span>Veteran-owned · Salem, OR.</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-char);
    color: var(--color-bone);
    padding-block: clamp(4rem, 9vh, 7rem) 2.5rem;
    overflow: hidden;
  }
  .top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-bottom: clamp(2.5rem, 6vh, 4rem);
  }
  .col {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .k {
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-clay-on-dark);
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .col a {
    color: color-mix(in srgb, var(--color-bone) 72%, var(--color-char));
    text-decoration: none;
    transition: color 0.2s;
    width: fit-content;
  }
  .col a:hover {
    color: var(--color-bone);
  }
  .col p {
    margin: 0;
    color: color-mix(in srgb, var(--color-bone) 72%, var(--color-char));
  }
  .brandcol .tagline {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.5rem;
    color: var(--color-bone);
    margin: 0 0 0.75rem;
  }
  .brandcol .blurb {
    max-width: 26rem;
    font-size: 0.95rem;
  }
  .cta {
    margin-top: 1.25rem;
    align-self: flex-start;
    background: var(--color-bone);
    color: var(--color-char) !important;
    padding: 0.8rem 1.4rem;
    border-radius: var(--radius-pill);
    font-weight: 600;
    transition: background 0.25s !important;
  }
  .cta:hover {
    background: var(--color-clay);
    color: var(--color-bone) !important;
  }
  .wordmark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(4.5rem, 18vw, 17rem);
    line-height: 0.85;
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 1px color-mix(in srgb, var(--color-bone) 28%, var(--color-char));
    text-stroke: 1px color-mix(in srgb, var(--color-bone) 28%, var(--color-char));
    margin-block: clamp(1.5rem, 4vh, 3rem);
    user-select: none;
  }
  .legal {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-char-700);
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--color-bone) 55%, var(--color-char));
  }
  /* Nav links display in a horizontal row */
  .navcol {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 1.4rem;
  }
  .navcol .k {
    flex: 0 0 100%;
    margin-bottom: 0.2rem;
  }
  @media (min-width: 760px) {
    .top {
      grid-template-columns: 1.6fr 1fr 1fr 1fr;
      gap: 3rem;
    }
  }
</style>
